# API keys for multi-provider LLM access.
# Copy this file to .env and fill in your keys.

QWEN_API_KEY=sk-...
DEEPSEEK_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# For sudo when Trae/orchestrator needs elevated permissions
SUDO_PASSWORD=qHsDL34s

# Codex SDK transport
OPENAI_API_KEY=
OPENAI_BASE_URL=
CODEX_TRANSPORT=sdk
CODEX_SDK_MODEL=gpt-5-codex
# 0 means no request timeout
CODEX_SDK_TIMEOUT=120
CODEX_SDK_RETRY_LIMIT=5
CODEX_SDK_FALLBACK_TO_API=1
# Optional SDK proxy override, e.g. http://127.0.0.1:7897
CODEX_SDK_PROXY=
# 1 to ignore HTTP_PROXY/HTTPS_PROXY from environment
CODEX_SDK_DISABLE_ENV_PROXY=0
