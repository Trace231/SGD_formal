{
  "rewrite_files": [
    {
      "path": "docs/CATALOG.md",
      "template": "orchestrator/sample_test/templates/CATALOG.md"
    },
    {
      "path": "docs/GLUE_TRICKS.md",
      "template": "orchestrator/sample_test/templates/GLUE_TRICKS.md"
    },
    {
      "path": "docs/METHODOLOGY.md",
      "template": "orchestrator/sample_test/templates/METHODOLOGY.md"
    }
  ],
  "regex_replacements": [
    {
      "path": "docs/APOLLO_ABLATION_GUIDE.md",
      "pattern": "subgradient_single\\.jsonl",
      "replacement": "sample_single.jsonl"
    },
    {
      "path": "docs/APOLLO_ABLATION_GUIDE.md",
      "pattern": "SubgradientMethod_scaffold_main_theorem",
      "replacement": "SampleMethod_scaffold_main_theorem"
    },
    {
      "path": "docs/APOLLO_ABLATION_GUIDE.md",
      "pattern": "Algorithms/SubgradientMethod_scaffold\\.lean",
      "replacement": "Algorithms/SampleMethod_scaffold.lean"
    },
    {
      "path": "docs/APOLLO_ABLATION_GUIDE.md",
      "pattern": "Algorithms/sorry\\.lean -> workspace/Algorithms/SubgradientMethod_scaffold\\.lean",
      "replacement": "Algorithms/sorry.lean -> workspace/Algorithms/SampleMethod_scaffold.lean"
    }
  ],
  "delete_globs": [
    "orchestrator/audits/audit_*_sorry.json",
    "orchestrator/audits/audit_*_SubgradientMethod*.json",
    "Algorithms/SubgradientMethod__a3_*.lean",
    "Algorithms/test.lean"
  ]
}
